<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        PMR Content Manager logo — Motorsport badge inspired by Content Manager aesthetics.
        Design: Circular badge with stylized speedometer gauge and racing chevrons.
          • Outer ring: Surface0Brush (#313244) to #45475a gradient — racing-badge border
          • Inner disc: MantleBrush (#181825) to #1e1e2e gradient — dark background
          • Gauge arc + needle + ticks: AccentBrush (#89B4FA) — motorsport dashboard feel
          • Racing chevrons at bottom: AccentBrush — speed/motion indicator
        ViewBox 64×64.  Reads cleanly at 16–48 px.
        SVG source of truth: Assets/logo.svg
        
        Inspiration: Content Manager's circular badge, gauge/speedometer motif,
        clean motorsport aesthetic — original design for PMR Content Manager.
    -->
    <DrawingImage x:Key="LogoDrawingImage">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- Outer ring (badge border) with gradient -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#45475a" Offset="0"/>
                            <GradientStop Color="#313244" Offset="1"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="32,32" RadiusX="30" RadiusY="30"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Inner disc (dark background) with gradient -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1e1e2e" Offset="0"/>
                            <GradientStop Color="#11111b" Offset="1"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="32,32" RadiusX="26" RadiusY="26"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Gauge arc (speedometer — 180° arc at top) -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#89B4FA" Thickness="3" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M14,36 A20,20 0 0 1 50,36"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Gauge tick marks (semi-transparent) -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#7089B4FA" Thickness="2" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="14,36" EndPoint="17,34"/>
                            <LineGeometry StartPoint="19,23" EndPoint="22,25"/>
                            <LineGeometry StartPoint="32,16" EndPoint="32,20"/>
                            <LineGeometry StartPoint="45,23" EndPoint="42,25"/>
                            <LineGeometry StartPoint="50,36" EndPoint="47,34"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Gauge needle (pointing towards high speed — top-right) -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#89B4FA" Thickness="3" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <LineGeometry StartPoint="32,38" EndPoint="42,22"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Needle pivot point (outer) -->
                <GeometryDrawing Brush="#89B4FA">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="32,38" RadiusX="4" RadiusY="4"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Needle pivot point (inner dark) -->
                <GeometryDrawing Brush="#11111b">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="32,38" RadiusX="2" RadiusY="2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Speed chevrons (bottom, racing feel — semi-transparent) -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#9989B4FA" Thickness="2" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <PathGeometry Figures="M24,50 L28,46 L24,42"/>
                            <PathGeometry Figures="M32,50 L36,46 L32,42"/>
                            <PathGeometry Figures="M40,50 L44,46 L40,42"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!--
        TODO (packaging): generate a .ico from logo.svg at 16/32/48/256 px and set
        Window.Icon="path/to/logo.ico" (BitmapFrame source) so the taskbar and
        Alt-Tab show the branded icon.  Route to Furiosa/Nux for the packaging step.
        Window.Icon with a DrawingImage source is not reliable for taskbar HICON
        conversion — do not use DrawingImage for Window.Icon.
    -->

</ResourceDictionary>
