<Window x:Class="EWSR_PMR_ModApp.UI.Dialogs.AmbiguousMappingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Resolve Ambiguous File Mappings"
        Height="540" Width="700"
        MinHeight="300" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#181825"
                Padding="16,12"
                BorderBrush="#313244"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Ambiguous File Mappings"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#CDD6F4"/>
                <TextBlock Text="Some files in the zip could not be mapped automatically. Choose the correct target path or skip each file."
                           FontSize="12"
                           Foreground="#A6ADC8"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Mapping list -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0">
            <ItemsControl x:Name="ItemsHost"
                          Margin="0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#181825"
                                BorderBrush="#313244"
                                BorderThickness="0,0,0,1"
                                Padding="16,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- File name -->
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="{Binding ZipPath}"
                                           FontWeight="SemiBold"
                                           Foreground="#CDD6F4"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding ZipPath}"/>

                                <!-- Reason -->
                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                           Text="{Binding Reason}"
                                           FontSize="11"
                                           Foreground="#FAB387"
                                           Margin="0,3,0,6"
                                           TextWrapping="Wrap"/>

                                <!-- Target picker -->
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="Target:"
                                           FontSize="12"
                                           Foreground="#A6ADC8"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding Options}"
                                          SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                                          Background="#313244"
                                          Foreground="#CDD6F4"
                                          BorderBrush="#45475A"
                                          FontSize="12"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer buttons -->
        <Border Grid.Row="2"
                Background="#181825"
                BorderBrush="#313244"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Skip All"
                        Click="SkipAll_Click"
                        Margin="0,0,8,0"
                        Background="#313244"
                        Foreground="#CDD6F4"
                        BorderBrush="#45475A"
                        Padding="12,6"/>
                <Button Content="Confirm"
                        Click="Confirm_Click"
                        Background="#89B4FA"
                        Foreground="#181825"
                        BorderBrush="#89B4FA"
                        FontWeight="SemiBold"
                        Padding="16,6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
